<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background_teal">

    <!-- Curio on the left -->
    <ImageView
        android:id="@+id/curio_image"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/curio_neutral"
        android:scaleType="fitCenter"
        android:contentDescription="Curio mascot"/>

    <!-- Streak count on the right -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/streak_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_fire_white"
            android:scaleType="fitCenter"
            android:contentDescription="Fire icon"/>

        <TextView
            android:id="@+id/streak_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>
